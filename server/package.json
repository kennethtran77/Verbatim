{
  "name": "verbatim-server",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/server/src/index.js",
    "dev": "ts-node-dev src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --config vitest.config.ts",
    "pretest:integration": "npm run db:test:reset",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:test:up": "docker compose -f tests/docker-compose.yml up -d --wait",
    "db:test:down": "docker compose -f tests/docker-compose.yml down -v",
    "db:test:reset": "ts-node tests/scripts/reset_db.ts",
    "clean": "npx rimraf dist -r && npx rimraf build -r",
    "init-frontend": "cd ../client && npm install",
    "bundle": "npm run clean && npm run build && cd ../client && npm run build && mv build ../server"
  },
  "keywords": [],
  "author": "kennethtran77",
  "license": "MIT",
  "description": "Backend for Verbatim",
  "dependencies": {
    "@types/pg": "^8.10.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "express": "^4.18.1",
    "french-verbs": "^4.2.2",
    "french-verbs-lefff": "^2.2.2",
    "pg": "^8.11.1",
    "socket.io": "^4.5.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/node": "^20.0.0",
    "concurrently": "^7.3.0",
    "rimraf": "^3.0.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
